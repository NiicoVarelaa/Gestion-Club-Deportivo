{
  "name": "gesclub",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "concurrently \"pnpm -F gesclub-server dev\" \"pnpm -F gesclub-client dev\"",
    "build": "pnpm -F gesclub-client build",
    "db:generate": "pnpm -F gesclub-server db:generate",
    "db:migrate": "pnpm -F gesclub-server db:migrate",
    "db:push": "pnpm -F gesclub-server db:push",
    "db:studio": "pnpm -F gesclub-server db:studio"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ],
    "overrides": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
